<section id="Contact" class="py-24 relative overflow-hidden flex items-center justify-center">
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto bg-white/5 backdrop-blur-2xl border border-white/10 rounded-[3rem] overflow-hidden shadow-2xl flex flex-col md:flex-row">
      <!-- Contact Info -->
      <div class="md:w-1/3 bg-orange-500 p-12 text-white">
        <h2 class="text-3xl font-bold mb-6">Hablemos</h2>
        <p class="text-orange-100 mb-8 text-lg">Estamos listos para llevar tu visión al siguiente nivel.</p>
        
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="h-10 w-10 rounded-full bg-white/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span>hello@stackcol.com</span>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="md:w-2/3 p-12">
        <form action="https://formsubmit.co/c591bc0c2f428f9901a1cfc327a19bc9" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-400 mb-2">Nombre</label>
              <input type="text" id="name" name="name" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 transition-colors" placeholder="Tu nombre">
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-400 mb-2">Email</label>
              <input type="email" id="email" name="email" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 transition-colors" placeholder="tu@email.com">
            </div>
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-400 mb-2">Asunto</label>
            <input type="text" id="subject" name="subject" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 transition-colors" placeholder="¿Cómo podemos ayudarte?">
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-400 mb-2">Mensaje</label>
            <textarea id="message" name="message" rows="4" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 transition-colors" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
          </div>

          <button type="submit" class="w-full bg-white text-black font-bold py-4 rounded-xl hover:bg-orange-500 hover:text-white transition-all transform hover:scale-[1.02] active:scale-[0.98] shadow-lg">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>




