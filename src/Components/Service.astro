<script>
  function setupServiceScroll() {
    const buttons = document.querySelectorAll('#Service [data-scroll]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-scroll');
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  }

  setupServiceScroll();
  document.addEventListener('astro:page-load', setupServiceScroll);
</script>
