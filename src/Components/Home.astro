<section id="Home" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-20">
  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
      <div class="lg:w-3/5 text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium uppercase tracking-widest text-orange-500 mb-6 animate-fade-in">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
          </span>
          StackCol Agency
        </div>
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.1] tracking-tight text-white mb-8">
          We make you look 
          <span class="relative inline-block text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-orange-700">
            different
            <div class="absolute -bottom-2 left-0 w-full h-1 bg-orange-500/20 blur-sm"></div>
          </span>
        </h1>
        
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
          Transformamos tus ideas en soluciones tecnológicas de vanguardia. Somos el motor de innovación para startups que buscan dominar el mercado digital.
        </p>

        <div class="flex flex-wrap gap-4">
          <button data-scroll="Contact" class="px-8 py-4 bg-orange-500 text-white font-bold rounded-2xl transition-all hover:bg-orange-600 hover:scale-105 active:scale-95 shadow-xl shadow-orange-500/20">
            Empezar proyecto
          </button>
          <button data-scroll="Service" class="px-8 py-4 bg-white/5 text-white font-semibold rounded-2xl border border-white/10 transition-all hover:bg-white/10">
            Ver servicios
          </button>
        </div>
      </div>

      <div class="lg:w-2/5 relative">
        <!-- Modern Abstract Visual (Dark Mode) -->
        <div class="relative w-72 h-72 md:w-96 md:h-96 mx-auto">
          <div class="absolute inset-0 bg-gradient-to-br from-orange-500 to-blue-600 rounded-[2rem] rotate-12 opacity-20 blur-2xl animate-pulse"></div>
          <div class="relative h-full w-full bg-white/5 backdrop-blur-3xl border border-white/10 rounded-[2rem] overflow-hidden flex items-center justify-center p-8 group shadow-2xl">
             <div class="grid grid-cols-2 gap-4 w-full">
                <div class="h-32 rounded-2xl bg-orange-500/20 border border-orange-500/30 group-hover:translate-y-[-10px] transition-transform duration-500"></div>
                <div class="h-32 rounded-2xl bg-blue-500/20 border border-blue-500/30 group-hover:translate-y-[10px] transition-transform duration-500 delay-75"></div>
                <div class="h-32 rounded-2xl bg-white/5 border border-white/10 group-hover:translate-x-[-10px] transition-transform duration-500 delay-100"></div>
                <div class="h-32 rounded-2xl bg-orange-500/40 border border-orange-500/50 group-hover:translate-x-[10px] transition-transform duration-500 delay-150"></div>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function setupHomeScroll() {
    const buttons = document.querySelectorAll('#Home [data-scroll]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-scroll');
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
      });
    });
  }

  setupHomeScroll();
  document.addEventListener('astro:page-load', setupHomeScroll);
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
